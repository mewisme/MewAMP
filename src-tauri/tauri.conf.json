{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MewAMP",
  "version": "0.5.6",
  "identifier": "com.mewisme.mewamp",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "MewAMP",
        "width": 1000,
        "height": 700,
        "minWidth": 1000,
        "minHeight": 700,
        "maximizable": true,
        "devtools": true,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "center": true,
        "visible": false
      },
      {
        "label": "splashscreen",
        "url": "splashscreen.html",
        "width": 300,
        "height": 300,
        "decorations": false,
        "resizable": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "shortDescription": "Local Apache, PHP, and MariaDB stack for desktop development with guided install, service control, logs, and diagnostics.",
    "longDescription": "MewAMP installs and manages Apache, PHP, MariaDB, and optional phpMyAdmin on your machine. A guided wizard resolves manifests, downloads runtimes, and writes configuration. Use the dashboard to start and stop services, browse logs, change settings, and export diagnostics. On Windows you can optionally add Microsoft SQL Express LocalDB alongside the stack.",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/manifest.json"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installerHooks": "./windows/installer-hooks.nsh"
      },
      "wix": {
        "fragmentPaths": [
          "./windows/terminate-app-on-uninstall.wxs"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNGQzNGNjUxRTkzMzlENUYKUldSZm5UUHBVZmJEUDY5RTNFQ1lmNzF2TnVjWE1lMjRDWHRoUVMzdVhSZ0xQS2RRQnFCSjU2VWIK",
      "endpoints": [
        "https://github.com/mewisme/MewAMP/releases/latest/download/latest.json"
      ]
    }
  }
}
